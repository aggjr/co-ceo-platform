{
  "version": 2,
  "model": "risk-by-functionality",
  "summary": "Cada unidade tem meta própria conforme criticidade e funcionalidades. Metas proporcionais (proportional: true) sobem com arquivos/linhas de código — sem teto fixo de ~100 casos.",
  "units": {
    "core.dal": {
      "lifecycle": "active",
      "criticality": "P0",
      "rationale": "Gateway e DAL interferem em persistência, audit, hodômetro e isolamento de todos os módulos.",
      "functionalities": [
        { "id": "tenant-isolation", "label": "Isolamento hierárquico (path)" },
        { "id": "audit-trail", "label": "Audit_logs na mesma transação" },
        { "id": "storage-meter", "label": "Hodômetro de armazenamento" },
        { "id": "soft-delete", "label": "Soft delete transacional" }
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 85,
        "minTestCasesFloor": 10,
        "minTestFilesFloor": 4,
        "testCasesPerSourceFile": 1.2,
        "testCasesPerFunctionality": 2
      }
    },
    "core.auth": {
      "lifecycle": "active",
      "criticality": "P0",
      "rationale": "Auth, JWT, impersonation e RBAC bloqueiam ou liberam todo o produto.",
      "functionalities": [
        { "id": "login", "label": "Login e contexto de sessão" },
        { "id": "impersonation", "label": "Emulação (cliente e plataforma)" },
        { "id": "rbac", "label": "Permissões e papéis (RBAC)" },
        { "id": "api-security", "label": "Middleware de proteção de rotas" }
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 80,
        "minTestCasesFloor": 10,
        "minTestFilesFloor": 5,
        "testCasesPerSourceFile": 1.2,
        "testCasesPerFunctionality": 2
      }
    },
    "core.telemetry": {
      "lifecycle": "active",
      "criticality": "P2",
      "rationale": "Telemetria não altera dados de negócio; falha não impede operação, mas afeta observabilidade.",
      "functionalities": [
        { "id": "usage-tracking", "label": "Rastreio de uso de telas/ações" }
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 60,
        "minTestCasesFloor": 2,
        "minTestFilesFloor": 1,
        "testCasesPerSourceFile": 1
      }
    },
    "cockpit.api": {
      "lifecycle": "active",
      "criticality": "P1",
      "rationale": "Cockpit expõe IAM, contratos e árvore organizacional para admin cliente e plataforma.",
      "functionalities": [
        { "id": "cockpit-iam", "label": "IAM e matriz de acesso" },
        { "id": "org-tree", "label": "Árvore organizacional" },
        { "id": "contract-admin", "label": "Gestão de contratos (plataforma)" }
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 70,
        "minTestCasesFloor": 5,
        "minTestFilesFloor": 2,
        "testCasesPerSourceFile": 1
      }
    },
    "core.quality": {
      "lifecycle": "active",
      "criticality": "P2",
      "rationale": "Painel e scripts de regressão — falha não derruba produção, mas impede visibilidade de qualidade.",
      "functionalities": [
        { "id": "regression-report", "label": "Relatório regression-latest.json" },
        { "id": "coverage-policy", "label": "Metas por unidade (coverage-policy)" },
        { "id": "impact-analysis", "label": "Reteste parcial por git diff" },
        { "id": "quality-dashboard", "label": "API / Cockpit Qualidade" }
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 50,
        "minTestCasesFloor": 6,
        "minTestFilesFloor": 2,
        "testCasesPerSourceFile": 1
      }
    },
    "invest": {
      "lifecycle": "active",
      "criticality": "P1",
      "rationale": "INVEST: livro razão, carteira, patrimônio — erro de PM ou custódia afeta decisão do usuário.",
      "functionalities": [
        { "id": "ledger", "label": "Livro razão / três preços" },
        { "id": "custody", "label": "Custódia e posições" },
        { "id": "portfolio-ui", "label": "Carteira exibida (PM vs cotação)" },
        { "id": "snapshots", "label": "Snapshots diários" }
      ],
      "sourcePaths": [
        "src/modules/invest/**",
        "src/controllers/InvestController.ts",
        "src/core/invest/**",
        "src/jobs/**/invest/**",
        "src/jobs/**/market/**"
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 70,
        "minTestCasesFloor": 40,
        "minTestFilesFloor": 8,
        "testCasesPerSourceFile": 1.5,
        "testCasesPerFunctionality": 3,
        "testCasesPer1000Lines": 2
      }
    },
    "invest.market-parity": {
      "lifecycle": "active",
      "criticality": "P0",
      "rationale": "Cotação em branco ou errada é falha visível ao usuário — validar contra brapi e opcoes.net.",
      "functionalities": [
        { "id": "equity-quote-brapi", "label": "Ação/FII: cotação = mercado (brapi)" },
        { "id": "option-chain-opcoes", "label": "Opção: strike/vencimento do catálogo opcoes.net" },
        { "id": "quote-not-pm", "label": "Cotação atualizada ≠ PM B3/gerencial" },
        { "id": "market-quotes-daily", "label": "Persistência market_quotes_daily" }
      ],
      "sourcePaths": [
        "src/core/invest/B3QuoteProvider.ts",
        "src/core/invest/portfolioMapper.ts",
        "src/core/invest/opcoesNetClient.ts",
        "src/core/invest/opcoesNetChainParser.ts",
        "src/core/market/**"
      ],
      "targets": {
        "proportional": true,
        "lineCoveragePct": 65,
        "minTestCasesFloor": 12,
        "minTestFilesFloor": 3,
        "testCasesPerSourceFile": 2,
        "testCasesPerFunctionality": 2
      }
    }
  }
}
