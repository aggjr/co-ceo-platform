# =============================================================================
# Credenciais para deploy EasyPanel — co-ceo-platform
# =============================================================================
#
# ORDEM:
#   FASE 1 — Preencha agora (app no EasyPanel, sem BD ainda)
#   FASE 2 — Depois de criar o MySQL no EasyPanel (campos DB_*)
#
# Copie para: config/deploy-credentials.env
# (ou use na raiz: deploy-credentials.template.env → deploy-credentials.env)
# O arquivo preenchido NÃO vai para o Git.
#
# =============================================================================

# =============================================================================
# FASE 1 — PREENCHA AGORA (BD ainda não existe)
# =============================================================================

# URL pública HTTPS do app co-ceo-platform (sem barra no final)
APP_URL=PREENCHER

APP_PORT=3001

# Segredo JWT (mín. 32 caracteres aleatórios)
JWT_SECRET=PREENCHER

NODE_ENV=production
PORTFOLIO_ORG_ID=org-holding-001

# Cron embutido na API (opcoes.net 03:15 America/Sao_Paulo) — pool MySQL separado da API
INVEST_CRON_ENABLED=1
INVEST_CRON_TZ=America/Sao_Paulo
INVEST_CRON_OPTIONS_AT=03:15
INVEST_CRON_STOCKS_AT=19:05
INVEST_CRON_RUN_ON_STARTUP=0
# Não regravar menu/textos do BD a cada boot (use seed manual ou UI_CATALOG_BOOTSTRAP_ON_START=1)
UI_CATALOG_BOOTSTRAP_ON_START=0

# Nomes no painel EasyPanel (ajuste se diferente)
EASYPANEL_PROJECT=co_ceo
EASYPANEL_APP_SERVICE=co-ceo-platform

# Você clica Redeploy manualmente no app? (sim | nao)
EASYPANEL_CAN_REDEPLOY_MANUAL=sim

# Webhook (EasyPanel → co-ceo-platform → Deploy). Cole também nas variáveis de ambiente do app no painel.
EASYPANEL_DEPLOY_WEBHOOK_URL=

# brapi: plano gratuito = 1 ticker por request (padrão no código)
BRAPI_TOKEN=
# BRAPI_TICKERS_PER_REQUEST=18
# BRAPI_REQUEST_DELAY_MS=400
CO_CEO_ADMIN_EMAIL=admin@coceo.com.br
CO_CEO_ADMIN_PASSWORD=
NOTES=

# =============================================================================
# FASE 2 — SÓ DEPOIS DE CRIAR O MYSQL NO EASYPANEL
# =============================================================================
#
# No EasyPanel você pode:
#   A) Usar o serviço co-ceo-db que já existe e criar só o database novo, OU
#   B) Criar um serviço MySQL novo só para co_ceo_platform
#
# Depois de criar, o painel mostra host, usuário e senha — aí preencha abaixo.
# Enquanto não tiver, deixe DB_SKIP=sim e os DB_* em branco ou PREENCHER_DEPOIS.
#
# =============================================================================

DB_SKIP=sim

# --- Preencher quando o MySQL existir no EasyPanel ---

DB_HOST=PREENCHER_DEPOIS
DB_HOST_INTERNAL=PREENCHER_DEPOIS
DB_PORT=3306
DB_USER=PREENCHER_DEPOIS
DB_PASSWORD=PREENCHER_DEPOIS
DB_NAME=co_ceo_platform

# Nome do serviço MySQL no EasyPanel (ex.: co-ceo-db ou um MySQL novo)
EASYPANEL_DB_SERVICE=co-ceo-db

# Database co_ceo_platform já criado? (sim | nao)
DB_ALREADY_CREATED=nao
