    "fetch:b3:quotes": "node ./node_modules/ts-node/dist/bin.js scripts/fetch-b3-quotes.ts",
    "invest:daily-close": "node ./node_modules/ts-node/dist/bin.js scripts/daily-invest-close.ts",
    "diagnose:patrimony": "node ./node_modules/ts-node/dist/bin.js scripts/diagnose-patrimony-components.ts",
    "import:broker:snapshot": "node ./node_modules/ts-node/dist/bin.js scripts/import-broker-custody-snapshot.ts",
    "apply:broker:snapshot": "node ./node_modules/ts-node/dist/bin.js scripts/apply-broker-holding-snapshot.ts",
    "reconcile:broker:options": "node ./node_modules/ts-node/dist/bin.js scripts/reconcile-broker-options.ts",
    "apply:broker:options-ledger": "node ./node_modules/ts-node/dist/bin.js scripts/apply-broker-options-pending-ledger.ts",
    "sync:market:quotes:stocks": "node ./node_modules/ts-node/dist/bin.js scripts/sync-market-quotes-stocks.ts",
    "sync:market:quotes:remote": "node scripts/run-remote-stock-quotes.js",
    "sync:options:market": "node ./node_modules/ts-node/dist/bin.js scripts/sync-option-market-opcoes-net.ts",
    "sync:options:custody": "node ./node_modules/ts-node/dist/bin.js scripts/sync-custody-option-quotes.ts",
    "sync:options:custody:remote": "node scripts/run-remote-custody-option-quotes.js",
    "sync:market:indices": "node ./node_modules/ts-node/dist/bin.js scripts/sync-market-indices.ts",
    "report:cdi": "node ./node_modules/ts-node/dist/bin.js scripts/report-cdi-coverage.ts",
    "seed:market:benchmarks": "node ./node_modules/ts-node/dist/bin.js scripts/seed-market-benchmarks.ts",
    "seed:market:remote": "node scripts/run-remote-market-benchmarks.js",
    "backfill:market:quotes": "node ./node_modules/ts-node/dist/bin.js scripts/backfill-market-quotes-history.ts",
    "backfill:patrimony:daily": "node ./node_modules/ts-node/dist/bin.js scripts/backfill-daily-patrimony.ts",
    "check:branch-overlap": "node ./node_modules/ts-node/dist/bin.js scripts/check-branch-overlap.ts",
    "audit:btg:notes-fees": "node ./node_modules/ts-node/dist/bin.js scripts/audit-btg-notes-fees-only.ts",
    "invest:purge-keep-opening": "node ./node_modules/ts-node/dist/bin.js scripts/purge-holding-keep-opening.ts",
    "invest:purge-month": "node ./node_modules/ts-node/dist/bin.js scripts/purge-invest-month.ts",
    "invest:reimport-btg-month": "node ./node_modules/ts-node/dist/bin.js scripts/reimport-btg-month.ts",
    "invest:reimport-btg-2026": "node ./node_modules/ts-node/dist/bin.js scripts/reimport-btg-months-2026.ts",
    "invest:rebuild-btg-notes": "node ./node_modules/ts-node/dist/bin.js scripts/rebuild-holding-from-btg-notes.ts",
    "task:list": "node scripts/task-queue.js list",
    "task:add": "node scripts/task-queue.js add",
    "task:claim": "node scripts/task-queue.js claim",
    "task:start": "node scripts/task-queue.js start",
    "task:done": "node scripts/task-queue.js done",
    "task:release": "node scripts/task-queue.js release",
    "task:sync": "node scripts/task-queue.js sync",
    "git:ensure-sync": "node scripts/ensure-code-synced.js",
    "git:check-version": "node scripts/ensure-code-version.js --check",
    "git:ensure-version": "node scripts/ensure-code-version.js",
    "verify:version-ui": "node scripts/verify-version-ui.js",
    "verify:integrate-version": "node scripts/verify-integrate-version.js",
    "git:ship": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-ship-changes.ps1",
    "git:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-sync-before-commit.ps1",
    "git:integrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-publish-to-main.ps1",
    "git:publish-main": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-publish-to-main.ps1",
    "db:import:full": "node scripts/import-full-dump.js",
    "fix:duplicate-cash": "ts-node scripts/delete-manual-cash.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.3",
    "pdfjs-dist": "^5.7.284",
    "solid-js": "^1.7.11"
  },
  "devDependencies": {
    "@solidjs/router": "^0.8.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.19.41",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vite-plugin-solid": "^2.11.12",
    "xlsx": "^0.18.5"
  }
}
