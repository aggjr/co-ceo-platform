{
  "name": "co-ceo-core",
  "version": "0.0.229",
  "description": "co-CEO Platform Core API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build --config frontend/vite.config.js && node dist/index.js",
    "dev": "concurrently -n api,web -c blue,green \"node ./node_modules/nodemon/bin/nodemon.js --exec \\\"node ./node_modules/ts-node/dist/bin.js\\\" src/index.ts\" \"node ./node_modules/vite/bin/vite.js --config frontend/vite.config.js\"",
    "dev:api": "nodemon --exec ts-node src/index.ts",
    "dev:web": "vite --config frontend/vite.config.js",
    "build": "tsc && node ./node_modules/vite/bin/vite.js build --config frontend/vite.config.js",
    "build:web": "vite build --config frontend/vite.config.js",
    "remote:recalc": "ts-node scripts/trigger-remote-recalc.ts",
    "test": "jest",
    "test:unit": "jest --selectProjects unit-core unit-middleware",
    "test:parity": "jest --selectProjects unit-core --testPathPattern=tests/parity",
    "test:parity:live": "node scripts/run-parity-live.js",
    "test:catalog:sync": "node scripts/sync-test-catalog.js",
    "test:impact:plan": "node scripts/test-impact.js",
    "test:regression": "node scripts/run-regression.js --mode=full",
    "test:regression:impact": "node scripts/run-regression.js --mode=impact",
    "test:regression:persist": "node scripts/run-regression.js --mode=full --persist",
    "test:full": "npm run test:regression",
    "test:fuzzer": "node scripts/genetic-fuzzer.js",
    "test:cron": "node scripts/cron-tests.js",
    "seed:iam": "node ./node_modules/ts-node/dist/bin.js src/database/seeds/005_iam_catalog.ts",
    "seed:admin": "node ./node_modules/ts-node/dist/bin.js src/database/seeds/001_super_admin.ts",
    "seed:holding": "node ./node_modules/ts-node/dist/bin.js src/database/seeds/002_holding_contract.ts",
    "seed:invest-access": "node ./node_modules/ts-node/dist/bin.js scripts/grant-invest-access-holding.ts",
    "seed:portfolio": "node ./node_modules/ts-node/dist/bin.js src/database/seeds/007_invest_portfolio_demo.ts",
    "seed:ui-catalog": "node ./node_modules/ts-node/dist/bin.js src/database/seeds/008_ui_catalog.ts",
    "seed:ui-catalog:raw": "node ./node_modules/ts-node/dist/bin.js scripts/seed-ui-catalog-raw.ts",
    "db:ui-catalog": "node ./node_modules/ts-node/dist/bin.js scripts/apply-ui-catalog-db.ts",
    "db:ui-catalog:remote": "node ./node_modules/ts-node/dist/bin.js scripts/apply-ui-catalog-db.ts --remote",
    "deploy:production": "node scripts/deploy-production.js",
